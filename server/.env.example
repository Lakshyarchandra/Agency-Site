# ─────────────────────────────────────────────
# CodePromix API Server — Environment Variables
# Copy to .env and fill in
# ─────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=CodePromix_site

JWT_SECRET=CodePromix_super_secret_jwt_2024_change_in_production

# Comma-separated frontend origins allowed by CORS
CORS_ORIGIN=http://localhost:3000

# Port for the API server
PORT=5000
